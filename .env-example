# You should change this, used in docker containers names and Laravel also
#   dont use spaces
APP_NAME=sisteco
# The folder name of this project, usually the same as APP_NAME
#   used to mount volumes inside containers
DOCKER_PROJECT_DIR_NAME=sisteco
# The standard APP_URL of Laravel
APP_URL=http://localhost:8004

# Database credentials
#   please, please, please: use strong password on production env
#   there will be a new postgres+postigis container with these credentials
DB_DATABASE=sisteco
DB_USERNAME=sisteco
DB_PASSWORD=sisteco

# Local or prod environment?

## LOCAL
APP_ENV=local
APP_DEBUG=true
LOG_LEVEL=debug
DOCKER_SERVE_PORT=8004

## PROD
#APP_ENV=production
#APP_DEBUG=false
#LOG_LEVEL=warning
## Remember to remove DOCKER_SERVE_PORT row in docker-compose.yml

# The hoqu domain necessary for the HoquClient service
HOQU_URL=http://0.0.0.0:8000
#HOQU_URL=https://hoqu.dev.maphub.it
#HOQU_URL=https://hoqu.maphub.it

#
# Stima prezzi — mappate in config/sisteco.php (solo numeri; per le percentuali no simbolo %)
#
# Aliquota IVA: usata per lordo/netto su prezzi e totali (es. 22 = 22%).
SISTECO_VAT=22
# Direzione lavori: percentuale sul costo base intervento (da prezzario × aree).
SISTECO_SUPERVISION=10
# Spese generali: percentuale sullo stesso basamento dell’intervento.
SISTECO_OVERHEADS=16
# Utile d’impresa: percentuale sul costo base intervento.
SISTECO_BUSINESS_PROFIT=10
# Mantenimento piattaforma: percentuale (su intervento o totale certificato a seconda del flusso di stima).
SISTECO_PLATFORM_MAINTENANCE=10
# Certificazione intervento: importo fisso in euro aggiunto al totale certificato dove previsto.
SISTECO_INTERVENTION_CERTIFICATION=1100
# Costi amministrativi / team: su CatalogArea è € fisso se c’è intervento; su CadastralParcel è % sul totale certificato.
SISTECO_TEAM_MANAGEMENT=3000
# Manutenzione: euro per ettaro all’anno (area intervento × valore × anni di piano).
SISTECO_MAINTENANCE=1250
# Certificazione manutenzione: importo fisso in euro per voce di certificazione nel ciclo manutenzione.
SISTECO_MAINTENANCE_CERTIFICATION=850
# Sentieri: costo in euro per km (la lunghezza in metri viene convertita in km nel calcolo).
SISTECO_HIKING_ROUTES_COST_PER_KM=3643.30

#
# Other docker configurations
#

# The (external) phpfpm port, used in docker-compose.yml
DOCKER_PHP_PORT=9104

# The (external) psql port, used in docker-compose.yml
DOCKER_PSQL_PORT=5504

# Host path mounted in the db container at /root/share (dumps, shared files)
DOCKER_SHARED_VOLUME=./docker/volumes/share

#
# Default Laravel env staff
#

APP_KEY=

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
